  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "generate-parser": "node -e \"const jison=require('jison'),fs=require('fs'),path=require('path');const g=fs.readFileSync(path.join(__dirname,'src/grammar/goscript.jison'),'utf8');const p=new jison.Generator(g,{type:'lalr',debug:false});fs.writeFileSync(path.join(__dirname,'src/grammar/parser.js'),p.generate());console.log('Parser generated OK');\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "jison": "^0.4.18"
  },
